# ---- Dependencies ----
node_modules/

# ---- Secrets / credentials ----
.env
.env.*
!.env.example
baileys_auth/

# ---- Runtime temp media (generated at request time) ----
uploads/
compressed/
assets/

# ---- FFmpeg binaries (provided by ffmpeg-static / ffprobe-static) ----
ffmpeg*

# ---- Logs ----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/

# ---- Temp / scratch files ----
tmp/
temp/
tmp_*.js
*.tmp

# ---- Editor / OS cruft ----
.vscode/
.idea/
.DS_Store
Thumbs.db

# ---- Test / coverage output ----
coverage/
.nyc_output/

# ---- Local dev harness (manual testing only) ----
dev-server.js

# Rendered animated-sticker (.tgs -> .webp) cache
tgs-cache/

# Raw sticker source packs (the editor ships the processed copies in public/stickers/)
super stickers/

# Kiro spec/workspace files (local only)
.kiro/

# ---- Local-only scratch / reference material (never commit) ----
# Decompiled third-party app (competitor APK) — proprietary, do not commit
decompiled/
# Chat screenshots / notes shared for reference
some images/
# Temp diagnostic scripts
_*.ps1
